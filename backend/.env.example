# Google Cloud Configuration
GOOGLE_CLOUD_PROJECT="your-project-id"
GOOGLE_CLOUD_LOCATION="us-central1"

# Gemini Configuration
# If you are using Vertex AI, authentication is handled via Service Account/ADC
# If using AI Studio, you might need an API Key for local testing
GEMINI_API_KEY="your-gemini-api-key-if-not-using-vertex"

# Application Settings
LOG_LEVEL="INFO"